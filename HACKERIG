class HackigApp:
    """Main application controller."""

    def __init__(self):
        self.ui = TermUI()
        self.engine = InstagramEngine()
        self.attack = AttackEngine(self.ui, self.engine)
        self.config = {
            'default_wordlist': 'passwords.txt',
            'delay': 0.5,
            'proxy_file': 'proxies.txt',
        }

    def check_dependencies(self):
        """Check and install dependencies."""
        if not HAS_PRIVATE_API:
            self.ui.print_warning("Instagram Private API not installed.")
            install = self.ui.get_input("Install it now? (y/n)", "y").lower() == 'y'
            if install:
                self.ui.print_status("Installing instagram-private-api...")
                os.system("pip install instagram-private-api 2>/dev/null || pip3 install instagram-private-api 2>/dev/null")
                self.ui.print_status("Installation attempted. Restart the tool.")
                sys.exit(0)
            else:
                self.ui.print_warning("Falling back to HTTP request method (less reliable)")

    def run(self):
        """Main application loop."""
        # Clear screen and show banner
        self.ui.clear()
        self.ui.print_banner()

        # Check if first run
        if not os.path.exists(f"{APP_NAME}_config.json"):
            self.ui.print_status("First run detected. Checking dependencies...")
            self.check_dependencies()
            time.sleep(1)

        # Check for results file
        if os.path.exists(f"{APP_NAME}_results.txt"):
            self.ui.print_status(f"Previous results found in {APP_NAME}_results.txt")

        while True:
            self.ui.clear()
            self.ui.print_banner()
            self.ui.print_menu()

            choice = self.ui.get_input("Select option")

            if choice == "1":
                self.mode_auto_attack_smart()
            elif choice == "2":
                self.mode_auto_attack_wordlist()
            elif choice == "3":
                self.mode_generate_list()
            elif choice == "4":
                self.mode_config()
