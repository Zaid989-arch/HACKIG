#                      PASSWORD GENERATORS
# ========================================================

class PasswordGenerator:
    """Generates smart password combinations from a base username/keywords."""

    COMMON_PASSWORDS = [
        "123456", "password", "123456789", "12345678", "12345",
        "1234567890", "qwerty123", "iloveyou", "monkey", "dragon",
        "abc123", "password1", "qwertyuiop", "letmein", "welcome",
        "admin123", "111111", "000000", "sunshine", "trustno1",
    ]

    COMMON_SUFFIXES = [
        "", "123", "1234", "12345", "123456", "1", "!",
        "@", "#", "2024", "2025", "2026", "!", "!!",
    ]

    COMMON_PREFIXES = [
        "", "!", "@", "#", "$",
    ]

    @staticmethod
    def from_username(username):
        """Generate password candidates based on username."""
        candidates = set()

        # Username variations
        candidates.add(username.lower())
        candidates.add(username.upper())
        candidates.add(username.capitalize())

        # Username + suffixes
        for suffix in PasswordGenerator.COMMON_SUFFIXES:
            candidates.add(f"{username.lower()}{suffix}")
            candidates.add(f"{username.capitalize()}{suffix}")

        # Prefix + username
        for prefix in PasswordGenerator.COMMON_PREFIXES:
            candidates.add(f"{prefix}{username.lower()}")

        # Leet speak variations
        leet = {
            'a': ['4', '@'], 'e': ['3'], 'i': ['1', '!'],
            'o': ['0'], 's': ['5', '$'], 't': ['7']
        }
        for i, char in enumerate(username.lower()):
            if char in leet:
                for replacement in leet[char]:
                    leet_variant = username.lower()[:i] + replacement + username.lower()[i+1:]
                    candidates.add(leet_variant)
                    for suffix in PasswordGenerator.COMMON_SUFFIXES[:5]:
                        candidates.add(f"{leet_variant}{suffix}")

        # Common passwords variation
        for common in PasswordGenerator.COMMON_PASSWORDS:
            candidates.add(common)

        return list(candidates)

    @staticmethod
    def from_keywords(keywords):
        """Generate passwords from a list of keywords."""
        candidates = set()
        for kw in keywords:
            kw = kw.strip().lower()
            if not kw:
                continue
            for suffix in PasswordGenerator.COMMON_SUFFIXES:
                candidates.add(f"{kw}{suffix}")
            for prefix in PasswordGenerator.COMMON_PREFIXES:
                candidates.add(f"{prefix}{kw}")
        return list(candidates)

    @staticmethod
    def from_wordlist(filepath):
        """Load passwords from a wordlist file."""
        if not os.path.exists(filepath):
            return []
        with open(filepath, 'r', encoding='latin-1', errors='ignore') as f:
            return [line.strip() for line in f if line.strip()]


